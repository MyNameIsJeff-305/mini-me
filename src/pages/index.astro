---
import MainLayout from "../layouts/MainLayout.astro";

import {
  Star,
  MapPin,
  BookOpen,
  GraduationCap,
  Baby,
  HeartHandshake,
  ShieldCheck,
  Sparkles,
  MoveRight,
  Phone,
  Mail,
  CircleHelp,
  Plus,
  CalendarDays,
  School,
  UsersRound,
  CheckCircle2,
  ChevronLeft,
  ChevronRight,
} from "@lucide/astro";
import { heroSlides, stats, programs, locations, steps, faqs } from "../data/homePage";
import { cleanPhone } from "../utils/formatters";


---

<MainLayout
  title="Daycare & Early Learning Centers in Miami, FL | Mini Me Learning Centers"
  description="Mini Me Learning Centers offers nurturing childcare and early education programs across four locations in Miami and South Florida."
>
  <section class="hero-shell">
    <div class="hero-orb hero-orb-yellow animate-float-slow"></div>
    <div class="hero-orb hero-orb-blue animate-float-soft"></div>

    <div class="container-shell">
      <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="animate-slide-up">
          <p class="hero-badge">
            <Star class="size-4 fill-current" aria-hidden="true" />
            Early Learning Centers Since 1999
          </p>

          <h1 class="mt-6 max-w-5xl">
            Daycare & <br />
            <span class="text-gradient">Early Learning Centers</span>
            <br />
            in Miami and South Florida.
          </h1>

          <p class="lead mt-6 max-w-2xl">
            A bright, nurturing place where little learners grow with confidence.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="/enroll" class="btn btn-primary">
              Start Enrollment
              <MoveRight class="size-4" aria-hidden="true" />
            </a>

            <a href="#locations" class="btn btn-outline">
              View Locations
              <MapPin class="size-4" aria-hidden="true" />
            </a>
          </div>

          <div class="mt-10 grid max-w-2xl gap-3 sm:grid-cols-3">
            {
              stats.map((item) => (
                <div class="card p-5">
                  <p class="font-display text-3xl font-black leading-none text-[rgb(var(--color-heading))]">
                    {item.value}
                  </p>
                  <p class="mt-2 text-sm font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-text-muted))]">
                    {item.label}
                  </p>
                </div>
              ))
            }
          </div>
        </div>

        <div
          class="hidden relative mx-auto w-full max-w-[24rem] animate-fade-in sm:max-w-[28rem] md:max-w-[32rem] lg:mx-0 lg:justify-self-end md:hidden lg:block sm:hidden"
          data-hero-slider
        >
          <div
            class="absolute inset-6 -z-10 rounded-full bg-[rgb(var(--color-bee-yellow)/0.22)] blur-3xl"
          >
          </div>

          <div
            class="glow-panel relative mx-auto w-full p-3 sm:p-4 md:p-5 lg:p-6"
            transition:name="hero-logo-panel"
          >
            <div
              class="relative h-[30rem] w-full overflow-hidden rounded-[var(--radius-2xl)] border border-[rgb(var(--color-border)/0.3)] bg-[rgb(var(--color-surface)/0.75)] shadow-[var(--shadow-card)] sm:h-[34rem] md:h-[38rem] lg:h-[40rem]"
            >
              {
                heroSlides.map((slide, index) => (
                  <figure
                    class:list={[
                      "absolute inset-0 overflow-hidden transition-opacity duration-700 ease-out",
                      index === 0 ? "opacity-100" : "opacity-0",
                    ]}
                    data-hero-slide
                    data-active={index === 0 ? "true" : "false"}
                  >
                    <img
                      src={slide.image}
                      alt={slide.alt}
                      class:list={[
                        "absolute inset-0 h-full w-full min-h-full min-w-full object-cover object-center",
                        index === 0 ? "animate-ken-burns" : "",
                      ]}
                      width="640"
                      height="800"
                      loading={index === 0 ? "eager" : "lazy"}
                      data-hero-slide-image
                    />

                    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.02)_0%,rgba(0,0,0,0.08)_45%,rgba(0,0,0,0.58)_100%)]" />

                    <figcaption class="absolute bottom-4 left-1/2 w-[86%] -translate-x-1/2 rounded-full border border-[rgb(var(--color-bee-gold))] bg-[rgb(var(--color-bee-gold)/0.88)] px-4 py-3 text-center shadow-[var(--shadow-card)] backdrop-blur-md sm:bottom-5 sm:w-[82%] sm:px-5">
                      <p class="flex items-center justify-center gap-2 text-xs font-black uppercase tracking-[0.14em] text-[rgb(var(--color-honey-light))] sm:text-sm sm:tracking-[0.16em]">
                        <Sparkles class="size-4 shrink-0" aria-hidden="true" />
                        {slide.label}
                      </p>
                    </figcaption>
                  </figure>
                ))
              }

              <button
                type="button"
                class="absolute left-3 top-1/2 z-20 grid size-10 -translate-y-1/2 place-items-center rounded-full border border-[rgb(var(--color-border)/0.35)] bg-[rgb(var(--color-surface)/0.82)] text-[rgb(var(--color-heading))] shadow-[var(--shadow-card)] backdrop-blur-md transition hover:border-[rgb(var(--color-bee-yellow)/0.55)] sm:left-4 sm:size-11"
                aria-label="Previous slide"
                data-hero-prev
              >
                <ChevronLeft class="size-5" aria-hidden="true" />
              </button>

              <button
                type="button"
                class="absolute right-3 top-1/2 z-20 grid size-10 -translate-y-1/2 place-items-center rounded-full border border-[rgb(var(--color-border)/0.35)] bg-[rgb(var(--color-surface)/0.82)] text-[rgb(var(--color-heading))] shadow-[var(--shadow-card)] backdrop-blur-md transition hover:border-[rgb(var(--color-bee-yellow)/0.55)] sm:right-4 sm:size-11"
                aria-label="Next slide"
                data-hero-next
              >
                <ChevronRight class="size-5" aria-hidden="true" />
              </button>

              <div
                class="absolute left-1/2 top-4 z-20 flex -translate-x-1/2 items-center gap-2 rounded-full border border-[rgb(var(--color-border)/0.28)] bg-[rgb(var(--color-surface)/0.72)] px-3 py-2 shadow-[var(--shadow-card)] backdrop-blur-md sm:top-5"
                aria-label="Slider pagination"
              >
                {
                  heroSlides.map((_, index) => (
                    <button
                      type="button"
                      class:list={[
                        "h-2.5 rounded-full transition",
                        index === 0
                          ? "w-6 bg-[rgb(var(--color-bee-yellow))]"
                          : "w-2.5 bg-[rgb(var(--color-white)/0.65)] hover:bg-[rgb(var(--color-bee-yellow)/0.75)]",
                      ]}
                      aria-label={`Go to slide ${index + 1}`}
                      data-hero-dot
                    />
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="section-shell-sm -mt-10">
      <div class="container-shell">
        <div
          class="surface grid gap-4 p-5 sm:grid-cols-3 md:p-6"
          aria-label="Mini Me highlights"
        >
          <div class="flex items-center gap-4">
            <span
              class="grid size-12 place-items-center rounded-full wing-gradient"
            >
              <Baby
                class="size-6 text-[rgb(var(--color-ink))]"
                aria-hidden="true"
              />
            </span>
            <div>
              <p class="font-black text-[rgb(var(--color-heading))]">
                Child-centered care
              </p>
              <p
                class="text-sm font-semibold text-[rgb(var(--color-text-muted))]"
              >
                Warm spaces for early growth.
              </p>
            </div>
          </div>
  
          <div class="flex items-center gap-4">
            <span
              class="grid size-12 place-items-center rounded-full bee-gradient"
            >
              <Sparkles
                class="size-6 text-[rgb(var(--color-ink))]"
                aria-hidden="true"
              />
            </span>
            <div>
              <p class="font-black text-[rgb(var(--color-heading))]">
                Established since 1999
              </p>
              <p
                class="text-sm font-semibold text-[rgb(var(--color-text-muted))]"
              >
                Trusted by South Florida families.
              </p>
            </div>
          </div>
  
          <div class="flex items-center gap-4">
            <span
              class="grid size-12 place-items-center rounded-full wing-gradient"
            >
              <MapPin
                class="size-6 text-[rgb(var(--color-ink))]"
                aria-hidden="true"
              />
            </span>
            <div>
              <p class="font-black text-[rgb(var(--color-heading))]">
                Four convenient centers
              </p>
              <p
                class="text-sm font-semibold text-[rgb(var(--color-text-muted))]"
              >
                Serving Miami and Homestead.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <section class="section-shell">
    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <p class="section-kicker mx-auto">
          <School class="size-4" aria-hidden="true" />
          Programs & Care
        </p>

        <h2 class="mt-5">
          Early learning built around care, confidence, and joyful discovery.
        </h2>

        <p class="lead mt-5">
          At Mini Me Learning Center, children are welcomed into a safe,
          nurturing environment where they can learn, play, explore, and grow at
          their own pace — supported every step of the way by caring educators.
        </p>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {
          programs.map(({ icon: Icon, title, description }) => (
            <article class="card p-6">
              <div class="grid mb-3 size-14 place-items-center rounded-[var(--radius-lg)] bg-[rgb(var(--color-bee-yellow)/0.14)] text-[rgb(var(--color-bee-yellow))]">
                <Icon class="size-7" aria-hidden="true" />
              </div>

              <h3 class="mt-8 text-xs">{title}</h3>

              <p class="mt-4 leading-7 text-[rgb(var(--color-text-soft))]">
                {description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-shell">
      <div class="glow-panel p-6 md:p-8">
        <div
          class="rounded-xl border border-[rgb(var(--color-border)/0.3)] bg-[rgb(var(--color-surface)/0.48)] p-6 md:p-8"
        >
          <p class="section-kicker">
            <HeartHandshake class="size-4" aria-hidden="true" />
            Why Mini Me?
          </p>

          <h2 class="mt-10">
            A warm, trusted place where your child can learn, grow, and feel at
            home.
          </h2>

          <p class="lead mt-5">
            Choosing the right learning center is a big decision. At Mini Me
            Learning Center, we create a safe, caring, and joyful environment
            where children feel supported, families feel confident, and every
            day brings new opportunities to discover.
          </p>

          <div class="mt-8 grid gap-4">
            {
              [
                "Easy support for busy families",
                "Playful learning with purpose",
                "A place to grow with confidence",
              ].map((title, index) => (
                <div class="flex gap-4">
                  <span class="mt-1 grid size-9 shrink-0 place-items-center rounded-full bee-gradient font-black text-[rgb(var(--color-ink))]">
                    {index + 1}
                  </span>
                  <div>
                    <h3 class="text-xl">{title}</h3>
                    <p class="mt-2 text-[rgb(var(--color-text-soft))]">
                      {index === 0 &&
                        "From enrollment questions to location details, we make it simple for parents to find the information they need and take the next step with confidence."}
                      {index === 1 &&
                        "Children learn best when they feel happy, curious, and encouraged. Our approach blends fun, structure, creativity, and care throughout the day."}
                      {index === 2 &&
                        "With caring teachers, age-appropriate activities, and a nurturing environment, we help children build the social, emotional, and early learning skills they need."}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="locations" class="section-shell">
    <div class="container-shell">
      <div
        class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between"
      >
        <div class="mx-auto max-w-3xl text-center">
          <p class="section-kicker">
            <MapPin class="size-4" aria-hidden="true" />
            Our Locations
          </p>

          <h2 class="mt-5">Find a Mini Me Learning Center near you.</h2>

          <p class="lead mt-5">
            With four convenient locations across South Florida, Mini Me
            Learning Center makes it easier for families to find trusted care
            and early learning close to home. Explore the center nearest you and
            take the next step toward enrollment.
          </p>
        </div>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        {
          locations.map((location) => (
            <article class="card overflow-hidden p-0">
              <div class="grid h-full gap-0 lg:grid-cols-[0.75fr_1.25fr]">
                {/* Location Image */}
                <div class="group relative block overflow-hidden bg-[rgb(var(--color-surface-soft))]">
                  <img
                    src={location.image}
                    alt={`${location.name} location`}
                    class="inset-0 object-cover transition duration-500 group-hover:scale-105"
                    loading="lazy"
                    style="height: 100%;"
                  />

                  <div class="absolute inset-0 bg-gradient-to-t from-black/35 via-black/5 to-transparent" />
                </div>

                {/* Location Content */}
                <div class="flex h-full flex-col justify-between gap-6 p-6 md:p-8">
                  <div>
                    <div class="flex items-start justify-between gap-4">
                      <div>
                        <p class="location-card__title">{location.name}</p>

                        <a
                          href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(
                            location.address,
                          )}`}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="mt-3 inline-flex items-start gap-2 leading-7 text-[rgb(var(--color-text-soft))] transition hover:text-[rgb(var(--color-bee-yellow))]"
                        >
                          <MapPin
                            class="mt-1 size-4 shrink-0"
                            aria-hidden="true"
                          />
                          <span>{location.address}</span>
                        </a>
                      </div>

                      <span class="grid size-12 shrink-0 place-items-center rounded-full bg-[rgb(var(--color-bee-yellow)/0.14)] text-[rgb(var(--color-bee-yellow))]">
                        <MapPin class="size-6" aria-hidden="true" />
                      </span>
                    </div>

                    <div class="location-card__meta mt-6">
                      <a
                        href={`tel:+1${cleanPhone(location.phone)}`}
                        class="inline-flex items-center gap-2 font-black transition hover:text-[rgb(var(--color-bee-yellow))]"
                      >
                        <Phone class="size-4" aria-hidden="true" />
                        {location.phone}
                      </a>

                      <a
                        href={`mailto:${location.email}`}
                        class="inline-flex items-center gap-2 font-bold transition hover:text-[rgb(var(--color-wing-blue))]"
                      >
                        <Mail class="size-4" aria-hidden="true" />
                        {location.email}
                      </a>
                    </div>
                  </div>

                  <div class="flex flex-col gap-3 sm:flex-row">
                    <a
                      href={location.slug}
                      class="btn btn-primary min-h-11 px-5 text-sm"
                    >
                      Details
                      <MoveRight class="size-4" aria-hidden="true" />
                    </a>

                    <a
                      href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(
                        location.address,
                      )}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn btn-outline min-h-11 px-5 text-sm"
                    >
                      Get Directions
                      <MapPin class="size-4" aria-hidden="true" />
                    </a>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-shell">
      <div class="glow-panel p-6 md:p-10 lg:p-12">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div>
            <p class="section-kicker">
              <CalendarDays class="size-4" aria-hidden="true" />
              Enrollment Path
            </p>

            <h2 class="mt-5">Start Your Child’s Journey with Confidence</h2>

            <p class="lead mt-5">
              Explore our learning centers, find the location that fits your
              family, and take the next step toward enrollment with ease.
            </p>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a href="/enroll" class="btn btn-primary">
                Start Enrollment
                <MoveRight class="size-4" aria-hidden="true" />
              </a>

              <a href="/contact" class="btn btn-outline">
                Ask a Question
                <CircleHelp class="size-4" aria-hidden="true" />
              </a>
            </div>
          </div>

          <div class="grid gap-4">
            {
              steps.map((step, index) => (
                <div class="card flex gap-5 p-5">
                  <div class="grid size-12 shrink-0 place-items-center rounded-full brand-gradient font-display text-xl font-black text-[rgb(var(--color-ink))]">
                    {index + 1}
                  </div>

                  <div>
                    <h3 class="text-2xl">{step.title}</h3>
                    <p class="mt-2 leading-7 text-[rgb(var(--color-text-soft))]">
                      {step.description}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <p class="section-kicker mx-auto">
          <CircleHelp class="size-4" aria-hidden="true" />
          Parent Questions
        </p>

        <h2 class="mt-5">Clear answers for families exploring Mini Me.</h2>

        <p class="lead mt-5">
          When considering a learning center, parents often have similar
          questions about programs, safety, enrollment, and more.
        </p>
      </div>

      <div class="mx-auto mt-10 grid max-w-4xl gap-4">
        {
          faqs.map((faq) => (
            <details class="card group p-5">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-5">
                <span class="font-display text-xl font-black tracking-[-0.03em] text-[rgb(var(--color-heading))]">
                  {faq.question}
                </span>

                <span class="grid size-9 shrink-0 place-items-center rounded-full bg-[rgb(var(--color-bee-yellow)/0.14)] font-black text-[rgb(var(--color-bee-yellow))] transition group-open:rotate-45">
                  <Plus class="size-5" aria-hidden="true" />
                </span>
              </summary>

              <p class="mt-4 leading-7 text-[rgb(var(--color-text-soft))]">
                {faq.answer}
              </p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell-sm">
    <div class="container-shell">
      <div
        class="glow-panel flex flex-col items-center justify-center p-8 text-center md:p-12"
      >
        <p class="section-kicker mx-auto">
          <UsersRound class="size-4" aria-hidden="true" />
          Let’s grow together
        </p>

        <h2 class="mx-auto mt-5 max-w-4xl">
          Ready to find the right Mini Me Learning Center for your family?
        </h2>

        <p class="lead mx-auto mt-5 max-w-2xl">
          Visit a location, ask about enrollment, or connect with the center
          closest to your home or work.
        </p>

        <div
          class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
        >
          <a href="#locations" class="btn btn-primary">
            Find a Location
            <MapPin class="size-4" aria-hidden="true" />
          </a>

          <a href="/enroll" class="btn btn-secondary">
            Enrollment Info
            <MoveRight class="size-4" aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener("astro:page-load", () => {
      const slider = document.querySelector("[data-hero-slider]");
      if (!(slider instanceof HTMLElement)) return;

      const slides = Array.from(
        slider.querySelectorAll("[data-hero-slide]"),
      ) as HTMLElement[];

      const images = Array.from(
        slider.querySelectorAll("[data-hero-slide-image]"),
      ) as HTMLImageElement[];

      const dots = Array.from(
        slider.querySelectorAll("[data-hero-dot]"),
      ) as HTMLButtonElement[];

      const prevButton = slider.querySelector("[data-hero-prev]");
      const nextButton = slider.querySelector("[data-hero-next]");

      if (!slides.length) return;

      let currentIndex = 0;
      let intervalId: number | undefined;

      const setSlide = (nextIndex: number) => {
        currentIndex = (nextIndex + slides.length) % slides.length;

        slides.forEach((slide, index) => {
          const isActive = index === currentIndex;

          slide.dataset.active = isActive ? "true" : "false";
          slide.classList.toggle("opacity-100", isActive);
          slide.classList.toggle("opacity-0", !isActive);

          images[index]?.classList.remove("animate-ken-burns");

          if (isActive) {
            window.setTimeout(() => {
              images[index]?.classList.add("animate-ken-burns");
            }, 20);
          }
        });

        dots.forEach((dot, index) => {
          const isActive = index === currentIndex;

          dot.classList.toggle("w-6", isActive);
          dot.classList.toggle("bg-[rgb(var(--color-bee-yellow))]", isActive);

          dot.classList.toggle("size-2.5", !isActive);
          dot.classList.toggle("bg-[rgb(var(--color-white)/0.45)]", !isActive);
        });
      };

      const nextSlide = () => setSlide(currentIndex + 1);
      const prevSlide = () => setSlide(currentIndex - 1);

      const startAutoplay = () => {
        window.clearInterval(intervalId);
        intervalId = window.setInterval(nextSlide, 5000);
      };

      nextButton?.addEventListener("click", () => {
        nextSlide();
        startAutoplay();
      });

      prevButton?.addEventListener("click", () => {
        prevSlide();
        startAutoplay();
      });

      dots.forEach((dot, index) => {
        dot.addEventListener("click", () => {
          setSlide(index);
          startAutoplay();
        });
      });

      slider.addEventListener("mouseenter", () => {
        window.clearInterval(intervalId);
      });

      slider.addEventListener("mouseleave", startAutoplay);

      setSlide(0);
      startAutoplay();
    });
  </script>
</MainLayout>
