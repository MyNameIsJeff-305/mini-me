---
import MainLayout from "../layouts/MainLayout.astro";
import {
  FileText,
  ShieldCheck,
  CheckCircle2,
  AlertCircle,
  Globe,
  Mail,
  Baby,
  BriefcaseBusiness,
  UsersRound,
  ExternalLink,
  LockKeyhole,
  ArrowRight,
} from "@lucide/astro";
import { termsSections, responsibilities, limitations } from "../data/termsPage";
---

<MainLayout
  title="Terms of Service | Mini Me Learning Centers"
  description="Read the Mini Me Learning Centers Terms of Service for information about using our website, submitting forms, enrollment inquiries, career applications, and website limitations."
>
  <section class="section-shell relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute left-[-12rem] top-16 h-80 w-80 rounded-full bg-[rgb(var(--color-bee-yellow)/0.18)] blur-3xl"
      >
      </div>
      <div
        class="absolute right-[-10rem] top-40 h-96 w-96 rounded-full bg-[rgb(var(--color-sky-blue)/0.16)] blur-3xl"
      >
      </div>
    </div>

    <div class="container-shell">
      <div class="flex flex-col items-center mx-auto max-w-4xl text-center">
        <p
          class="section-kicker mx-auto inline-flex items-center justify-center text-center"
        >
          <FileText class="size-4" aria-hidden="true" />
          Terms of Service
        </p>

        <h1
          class="mx-auto mt-5 text-center text-5xl leading-[1.02] tracking-[-0.05em] md:text-7xl"
        >
          Website terms, made clear and simple.
        </h1>

        <p class="lead mx-auto mt-6 max-w-2xl text-center">
          These Terms of Service explain the basic rules and conditions for
          using the Mini Me Learning Centers website.
        </p>

        <p
          class="mx-auto mt-5 max-w-2xl text-sm font-bold text-[rgb(var(--color-text-soft))]"
        >
          Last updated: May 2026
        </p>
      </div>
    </div>
  </section>

  <section class="section-shell-sm">
    <div class="container-shell">
      <div class="glow-panel mx-auto max-w-5xl p-6 md:p-8">
        <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
          <div>
            <p class="section-kicker">
              <FileText class="size-4" aria-hidden="true" />
              Overview
            </p>

            <h2 class="mt-5 text-4xl tracking-[-0.05em] md:text-5xl">
              Agreement to these terms.
            </h2>
          </div>

          <div class="space-y-5 leading-8 text-[rgb(var(--color-text-soft))]">
            <p>
              By accessing or using this website, you agree to these Terms of
              Service. If you do not agree with these terms, please do not use
              the website.
            </p>

            <p>
              These terms apply only to use of the Mini Me Learning Centers
              website. They do not replace any separate enrollment agreements,
              employment documents, childcare policies, parent handbooks,
              center-specific requirements, or other written agreements that may
              apply separately.
            </p>

            <p>
              Mini Me Learning Centers may update these terms from time to time.
              Continued use of the website after updates means you accept the
              revised terms.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell-sm">
    <div class="container-shell">
      <div class="flex flex-col items-center mx-auto max-w-3xl text-center">
        <p
          class="section-kicker mx-auto inline-flex items-center justify-center text-center"
        >
          <ShieldCheck class="size-4" aria-hidden="true" />
          Website Terms
        </p>

        <h2
          class="mx-auto mt-5 text-center text-4xl tracking-[-0.05em] md:text-6xl"
        >
          How this website may be used.
        </h2>

        <p class="lead mx-auto mt-5 max-w-2xl text-center">
          Our website is designed to help families, applicants, and visitors
          learn more about Mini Me Learning Centers.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {
          termsSections.map((section) => {
            const Icon = section.icon;

            return (
              <article class="rounded-[var(--radius-xl)] border border-[rgb(var(--color-border)/0.32)] bg-[rgb(var(--color-surface)/0.55)] p-6">
                <div class="flex h-14 w-14 mb-10 items-center justify-center rounded-2xl bg-[rgb(var(--color-bee-yellow)/0.16)] text-[rgb(var(--color-bee-yellow))]">
                  <Icon class="h-6 w-6" aria-hidden="true" />
                </div>

                <h3 class="mt-5 text-2xl tracking-[-0.04em]">
                  {section.title}
                </h3>

                <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                  {section.content}
                </p>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="section-shell-sm">
    <div class="container-shell">
      <div
        class="glow-panel grid gap-8 p-6 md:p-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start"
      >
        <div>
          <p class="section-kicker">
            <UsersRound class="size-4" aria-hidden="true" />
            User Responsibilities
          </p>

          <h2 class="mt-5 text-4xl tracking-[-0.05em] md:text-5xl">
            Please use the website responsibly.
          </h2>

          <p class="mt-5 leading-7 text-[rgb(var(--color-text-soft))]">
            When using this website or submitting information through a form, you
            agree to act respectfully, lawfully, and accurately.
          </p>
        </div>

        <div class="grid gap-3">
          {
            responsibilities.map((item) => (
              <div class="flex gap-3 rounded-[var(--radius-lg)] border border-[rgb(var(--color-border)/0.3)] bg-[rgb(var(--color-surface)/0.45)] p-4">
                <CheckCircle2 class="mt-0.5 size-5 shrink-0 text-[rgb(var(--color-bee-yellow))]" />
                <p class="text-sm font-bold leading-6 text-[rgb(var(--color-text-soft))]">
                  {item}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell-sm">
    <div class="container-shell">
      <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
        <div class="glow-panel p-6 md:p-8">
          <p class="section-kicker">
            <AlertCircle class="size-4" aria-hidden="true" />
            No Guarantees
          </p>

          <h2 class="mt-5 text-4xl tracking-[-0.05em] md:text-5xl">
            Website submissions do not guarantee enrollment or employment.
          </h2>

          <div
            class="mt-5 space-y-5 leading-8 text-[rgb(var(--color-text-soft))]"
          >
            <p>
              Submitting an enrollment inquiry does not guarantee that a space is
              available, that a child is accepted for enrollment, or that
              enrollment has been completed.
            </p>

            <p>
              Submitting a career application does not guarantee an interview,
              employment, or any specific job opportunity.
            </p>

            <p>
              Any enrollment, employment, pricing, program, or availability
              information shared through the website is subject to confirmation
              by the appropriate Mini Me Learning Center team member.
            </p>
          </div>
        </div>

        <div
          class="rounded-[var(--radius-2xl)] border border-[rgb(var(--color-border)/0.32)] bg-[rgb(var(--color-surface)/0.55)] p-6"
        >
          <div
            class="flex h-14 w-14 items-center justify-center rounded-2xl bg-[rgb(var(--color-bee-yellow)/0.16)] text-[rgb(var(--color-bee-yellow))]"
          >
            <ShieldCheck class="h-7 w-7" aria-hidden="true" />
          </div>

          <h3 class="mt-6 text-3xl tracking-[-0.04em]">
            Final confirmation happens directly with our team.
          </h3>

          <p class="mt-4 leading-7 text-[rgb(var(--color-text-soft))]">
            Please speak with the appropriate Mini Me Learning Center location
            for official details about enrollment, openings, documents,
            eligibility, and next steps.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell-sm">
    <div class="container-shell">
      <div
        class="glow-panel grid gap-8 p-6 md:p-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start"
      >
        <div>
          <p class="section-kicker">
            <ExternalLink class="size-4" aria-hidden="true" />
            Third-Party Services
          </p>

          <h2 class="mt-5 text-4xl tracking-[-0.05em] md:text-5xl">
            Some tools and links are outside our website.
          </h2>
        </div>

        <div class="space-y-5 leading-8 text-[rgb(var(--color-text-soft))]">
          <p>
            This website may include links or integrations with third-party
            services, such as maps, social media platforms, form handling,
            analytics, email tools, or external websites.
          </p>

          <p>
            Mini Me Learning Centers is not responsible for the content,
            availability, security, practices, or policies of third-party
            websites or services. Your use of third-party websites may be subject
            to their own terms and privacy policies.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell-sm">
    <div class="container-shell">
      <div
        class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start"
      >
        <div>
          <p class="section-kicker">
            <AlertCircle class="size-4" aria-hidden="true" />
            Limitations
          </p>

          <h2 class="mt-5 text-4xl tracking-[-0.05em] md:text-6xl">
            Important limitations to understand.
          </h2>

          <p class="lead mt-5">
            Our website is meant to be helpful, but it should not be treated as
            the final source for official center decisions or agreements.
          </p>
        </div>

        <div class="grid gap-3">
          {
            limitations.map((item) => (
              <div class="flex gap-3 rounded-[var(--radius-lg)] border border-[rgb(var(--color-border)/0.3)] bg-[rgb(var(--color-surface)/0.45)] p-4">
                <CheckCircle2 class="mt-0.5 size-5 shrink-0 text-[rgb(var(--color-bee-yellow))]" />
                <p class="text-sm font-bold leading-6 text-[rgb(var(--color-text-soft))]">
                  {item}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell-sm">
    <div class="container-shell">
      <div
        class="glow-panel grid gap-8 p-6 md:p-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start"
      >
        <div>
          <p class="section-kicker">
            <LockKeyhole class="size-4" aria-hidden="true" />
            Intellectual Property
          </p>

          <h2 class="mt-5 text-4xl tracking-[-0.05em] md:text-5xl">
            Website content belongs to Mini Me Learning Centers.
          </h2>
        </div>

        <div class="space-y-5 leading-8 text-[rgb(var(--color-text-soft))]">
          <p>
            The text, graphics, branding, images, layout, design elements, and
            other content on this website are owned by or licensed to Mini Me
            Learning Centers, unless otherwise stated.
          </p>

          <p>
            You may view and use the website for personal, informational
            purposes. You may not copy, reproduce, distribute, modify, or
            republish website content for commercial purposes without written
            permission.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell-sm">
    <div class="container-shell">
      <div class="flex flex-col items-center glow-panel p-8 text-center md:p-12">
        <p
          class="section-kicker mx-auto inline-flex items-center justify-center text-center"
        >
          <Mail class="size-4" aria-hidden="true" />
          Questions About These Terms
        </p>

        <h2
          class="mx-auto mt-5 max-w-4xl text-center text-4xl tracking-[-0.05em] md:text-6xl"
        >
          Need help understanding these Terms of Service?
        </h2>

        <p class="lead mx-auto mt-5 max-w-2xl text-center">
          Contact Mini Me Learning Centers if you have questions about using
          this website or submitting information online.
        </p>

        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
          <a href="/contact" class="btn btn-primary">
            Contact Us
            <ArrowRight class="size-4" aria-hidden="true" />
          </a>

          <a href="/privacy-policy" class="btn btn-secondary">
            Privacy Policy
            <ShieldCheck class="size-4" aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>