---
import {
  MapPin,
  Phone,
  Mail,
  MoveRight,
  CalendarDays,
  Star,
  ExternalLink,
  HeartHandshake,
  GraduationCap,
} from "@lucide/astro";

const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: "Home", href: "/" },
  { label: "Locations", href: "/locations" },
  { label: "Programs", href: "/programs" },
  { label: "Enroll", href: "/enroll" },
  { label: "Careers", href: "/careers" },
  { label: "FAQ", href: "/faq" },
];

const parentLinks = [
  { label: "Schedule a Visit", href: "/contact" },
  { label: "Enrollment Info", href: "/enroll" },
  { label: "Programs & Scholarships", href: "/programs" },
  { label: "Inclusion", href: "/inclusion" },
];

const locations = [
  {
    name: "Mini Me Daycare Learning Center",
    address: "9851 SW 1st St, Fountainebleau, FL 33174",
    phone: "(305) 227-2289",
    email: "Minimelc1@att.net",
  },
  {
    name: "Mini Me Learning Center II",
    address: "11865 Southwest 26th Street, Miami, FL 33175",
    phone: "(305) 227-9111",
    email: "Minimedaycare@bellsouth.net",
  },
  {
    name: "Mini Me Learning Center III",
    address: "7300 SW 152 Ave, Miami, FL 33193",
    phone: "(305) 388-2098",
    email: "Minimelc3@att.net",
  },
  {
    name: "Mini Me Learning Center IV",
    address: "15260 SW 280 St, Homestead, FL 33032",
    phone: "(786) 410-8991",
    email: "Minimelc4@att.net",
  },
];

const cleanPhone = (phone: string) => phone.replace(/\D/g, "");
---

<footer class="site-footer relative overflow-hidden border-t border-[rgb(var(--color-border)/0.28)]">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute left-[-8rem] top-[-8rem] size-[24rem] rounded-full bg-[rgb(var(--color-wing-blue)/0.14)] blur-3xl"
    >
    </div>

    <div
      class="absolute bottom-[-10rem] right-[-8rem] size-[28rem] rounded-full bg-[rgb(var(--color-bee-yellow)/0.13)] blur-3xl"
    >
    </div>

    <div class="soft-grid absolute inset-0 opacity-50"></div>
  </div>

  <div class="container-shell pt-16 md:pt-20">
    <div
      class="glow-panel grid gap-8 p-6 md:grid-cols-[1.15fr_0.85fr] md:items-center md:p-10 lg:p-12"
    >
      <div>
        <p class="section-kicker">
          <CalendarDays class="size-4" aria-hidden="true" />
          Ready to visit?
        </p>

        <h2 class="mt-5 max-w-3xl">
          Find the right Mini Me location for your little learner.
        </h2>

        <p class="lead mt-5 max-w-2xl">
          Explore our learning centers, ask about enrollment, and discover a
          warm early education environment built for children to grow with care,
          confidence, and joy.
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-1 lg:grid-cols-2">
        <a href="/contact" class="btn btn-primary w-full">
          Schedule a Visit
          <MoveRight class="size-4" aria-hidden="true" />
        </a>

        <a href="/locations" class="btn btn-secondary w-full">
          View Locations
          <MapPin class="size-4" aria-hidden="true" />
        </a>
      </div>
    </div>
  </div>

  <div class="container-shell py-14 md:py-16">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_0.7fr_0.8fr_1.15fr]">
      <div>
        <a
          href="/"
          class="group inline-flex items-center gap-4 rounded-[var(--radius-xl)] outline-none transition-transform duration-300 hover:-translate-y-0.5 focus-visible:ring-4 focus-visible:ring-[rgb(var(--color-bee-yellow)/0.35)]"
          aria-label="Mini Me Learning Centers home"
          transition:name="footer-logo"
        >
          <div
            class="grid size-20 place-items-center rounded-[var(--radius-lg)] border border-[rgb(var(--color-border)/0.35)] bg-[rgb(var(--color-surface)/0.75)] p-2 shadow-[var(--shadow-card)] backdrop-blur-md transition duration-300 group-hover:border-[rgb(var(--color-bee-yellow)/0.55)]"
          >
            <img
              src="/images/mini-me-logo.webp"
              alt="Mini Me Learning Centers logo"
              class="logo-shadow h-full w-full object-contain"
              width="80"
              height="80"
              loading="lazy"
            />
          </div>

          <div>
            <span
              class="block font-display text-3xl font-black leading-none tracking-[-0.05em] text-[rgb(var(--color-heading))]"
            >
              Mini Me
            </span>

            <span
              class="mt-1 block text-xs font-black uppercase tracking-[0.2em] text-[rgb(var(--color-text-muted))]"
            >
              Learning Centers
            </span>
          </div>
        </a>

        <p class="mt-6 max-w-sm text-base leading-7 text-[rgb(var(--color-text-soft))]">
          Early childhood education and childcare centers serving families
          across Miami and South Florida since 1999.
        </p>

        <div class="star-divider mt-6">
          <Star class="size-5 fill-current" aria-hidden="true" />
          <span class="font-black">Est. 1999</span>
        </div>

        <div class="mt-6 grid gap-3">
          <div class="program-pill">
            <HeartHandshake class="size-4" aria-hidden="true" />
            Caring classrooms
          </div>

          <div class="program-pill">
            <GraduationCap class="size-4" aria-hidden="true" />
            Early learning support
          </div>
        </div>
      </div>

      <div>
        <h3 class="font-display text-2xl font-black tracking-[-0.04em]">
          Explore
        </h3>

        <ul class="mt-5 grid gap-3">
          {
            quickLinks.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="group inline-flex items-center gap-2 text-sm font-extrabold text-[rgb(var(--color-text-soft))] transition hover:text-[rgb(var(--color-heading))]"
                >
                  <span
                    class="size-1.5 rounded-full bg-[rgb(var(--color-bee-yellow))] opacity-60 transition group-hover:opacity-100"
                    aria-hidden="true"
                  ></span>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="font-display text-2xl font-black tracking-[-0.04em]">
          For Parents
        </h3>

        <ul class="mt-5 grid gap-3">
          {
            parentLinks.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="group inline-flex items-center gap-2 text-sm font-extrabold text-[rgb(var(--color-text-soft))] transition hover:text-[rgb(var(--color-heading))]"
                >
                  <span
                    class="size-1.5 rounded-full bg-[rgb(var(--color-wing-blue))] opacity-70 transition group-hover:opacity-100"
                    aria-hidden="true"
                  ></span>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="font-display text-2xl font-black tracking-[-0.04em]">
          Contact a Location
        </h3>

        <div class="mt-5 grid gap-3">
          {
            locations.map((location) => (
              <div class="rounded-[var(--radius-lg)] border border-[rgb(var(--color-border)/0.28)] bg-[rgb(var(--color-surface)/0.46)] p-4">
                <p class="font-black text-[rgb(var(--color-heading))]">
                  {location.name}
                </p>

                <p class="mt-2 flex gap-2 text-sm leading-6 text-[rgb(var(--color-text-soft))]">
                  <MapPin class="mt-0.5 size-4 shrink-0 text-[rgb(var(--color-bee-yellow))]" aria-hidden="true" />
                  <span>{location.address}</span>
                </p>

                <div class="mt-3 flex flex-wrap gap-x-4 gap-y-2 text-sm font-bold">
                  <a
                    href={`tel:+1${cleanPhone(location.phone)}`}
                    class="inline-flex items-center gap-1.5 text-[rgb(var(--color-text-soft))] transition hover:text-[rgb(var(--color-bee-yellow))]"
                  >
                    <Phone class="size-4" aria-hidden="true" />
                    {location.phone}
                  </a>

                  <a
                    href={`mailto:${location.email}`}
                    class="inline-flex items-center gap-1.5 text-[rgb(var(--color-text-soft))] transition hover:text-[rgb(var(--color-wing-blue))]"
                  >
                    <Mail class="size-4" aria-hidden="true" />
                    Email
                    <ExternalLink class="size-3.5" aria-hidden="true" />
                  </a>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-[rgb(var(--color-border)/0.25)]">
    <div
      class="container-shell flex flex-col gap-4 py-6 text-sm font-bold text-[rgb(var(--color-text-muted))] md:flex-row md:items-center md:justify-between"
    >
      <p>
        © {currentYear} Mini Me Learning Centers. All rights reserved.
      </p>

      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <a href="/privacy-policy" class="transition hover:text-[rgb(var(--color-heading))]">
          Privacy Policy
        </a>

        <a href="/terms" class="transition hover:text-[rgb(var(--color-heading))]">
          Terms
        </a>

        <a href="/accessibility" class="transition hover:text-[rgb(var(--color-heading))]">
          Accessibility
        </a>
      </div>
    </div>
  </div>
</footer>